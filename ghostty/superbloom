# Superbloom — Ghostty theme. Companion to the superbloom.nvim colorscheme.
# Install: cp ghostty/superbloom ~/.config/ghostty/themes/superbloom
# Then set `theme = superbloom` in ~/.config/ghostty/config

# ANSI colors want distinct hues, not the nvim theme's analogous green harmony —
# cyan comes from sky instead of a third green so ls's green/cyan stay distinct.
# Only styles ANSI output (ls, plain git diff, TUIs); bat/delta/nvim use a
# separate 24-bit theme.

# Normal
palette = 0=#253628
palette = 1=#c96f8d
palette = 2=#9ab992
palette = 3=#e6814f
palette = 4=#88a9e6
palette = 5=#a68fd1
palette = 6=#8fbfdc
palette = 7=#aba7b6

# Bright
palette = 8=#81917d
palette = 9=#e09aaa
palette = 10=#9ac6a6
palette = 11=#e2c583
palette = 12=#88a9e6
palette = 13=#cabfe3
palette = 14=#8fbfdc
palette = 15=#e5eadf

background = #121d16
foreground = #e5eadf

# Poppy cursor keeps the theme's warm accent always on screen.
cursor-color = #e6814f
cursor-text = #121d16

selection-background = #314839
selection-foreground = #e5eadf
