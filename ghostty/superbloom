# Superbloom — Ghostty theme
# A green terminal theme inspired by the California superbloom.
# Companion to the superbloom.nvim colorscheme.
#
# Install:
#   cp extras/ghostty/superbloom ~/.config/ghostty/themes/superbloom
# Then in ~/.config/ghostty/config:
#   theme = superbloom

# The 16 ANSI colors are a categorical scale — they want distinct hues, not the
# analogous green harmony the nvim syntax theme uses. The one real adjustment:
# cyan comes from sky (the palette's bluest color) instead of a third green, so
# green (ls executables) and cyan (ls symlinks) stay clearly distinct. Brights
# repeat blue/cyan to keep the cool end uncrowded. phacelia, the nvim keyword
# teal, sits the terminal out.
#
# Scope: this file only styles ANSI output — ls, plain `git diff`, TUIs, and
# ANSI-based shell prompts. Syntax highlighting in bat/delta/nvim renders from a
# separate 24-bit theme, not these 16 colors, so code keeps the softer nvim
# palette regardless of what is set here.

# Normal
palette = 0=#26382b
palette = 1=#c96f8d
palette = 2=#92ad8b
palette = 3=#e69a4f
palette = 4=#88a9e6
palette = 5=#b6a6d5
palette = 6=#8fbfdc
palette = 7=#adbaa6

# Bright
palette = 8=#81917d
palette = 9=#e09aaa
palette = 10=#9ac6a6
palette = 11=#e2c583
palette = 12=#88a9e6
palette = 13=#cabfe3
palette = 14=#8fbfdc
palette = 15=#e5eadf

background = #142018
foreground = #e5eadf

# Poppy cursor — the palette's signature warm accent, always on screen. A bare
# terminal rarely prints ANSI yellow, so without this the theme reads as pure
# green; the cursor is the one always-visible surface that can carry the warmth.
cursor-color = #e69a4f
cursor-text = #142018

selection-background = #314839
selection-foreground = #e5eadf
